{
  "name": "xhs-downloader-backend",
  "description": "Backend API server for XHS Downloader",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server-new.ts",
    "dev:old": "tsx server.ts",
    "start": "node dist/server-new.js",
    "build": "tsc --project tsconfig.server.json",
    "preview": "node dist/server-new.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "archiver": "^7.0.1",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "uuid": "^13.0.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
