{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "moduleResolution": "node",
    "outDir": "./dist",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "lib": ["ES2020"]
  },
  "include": ["server-new.ts", "server/**/*.ts"]
}
